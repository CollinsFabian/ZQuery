{
    "name": "zi/zquery",
    "description": "Focused fluent SQL query builder for PHP 8.2+",
    "keywords": ["query-builder", "php", "database", "sql", "fluent-interface", "mysql", "postgresql", "transactions", "pdo", "mysqli"],
    "license": "proprietary",
    "type": "library",
    "authors": [
        {
            "name": "CollinsFabian",
            "email": "alphaalive22@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "ZQuery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZQuery\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php tests/SqlCompilationTest.php"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
